generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  preferences  Json           @default("{}")
  timezone     String         @default("America/New_York")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  courses       Course[]
  tasks         Task[]
  scheduleBlocks ScheduleBlock[]
  fileUploads   FileUpload[]
  chatMessages  ChatMessage[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Course {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#6B7280")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]
  files FileUpload[]

  @@index([userId])
}

model Task {
  id             String    @id @default(cuid())
  courseId        String?
  userId         String
  title          String
  description    String    @default("")
  dueDate        DateTime?
  priority       Int       @default(2) // 1=highest, 5=lowest
  estimatedHours Float     @default(1.0)
  status         String    @default("pending") // pending, in_progress, completed
  recurrence     Json?     // { pattern: "weekly", days: [1,3,5] }
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  course         Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleBlocks ScheduleBlock[]

  @@index([userId])
  @@index([courseId])
  @@index([dueDate])
}

model ScheduleBlock {
  id        String   @id @default(cuid())
  userId    String
  taskId    String?
  date      DateTime @db.Date
  startTime String   // "HH:MM" format
  endTime   String   // "HH:MM" format
  isLocked  Boolean  @default(false)
  label     String?  // For locked blocks without tasks (e.g., "CS310 Lecture")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([taskId])
}

model FileUpload {
  id            String    @id @default(cuid())
  userId        String
  courseId       String?
  originalName  String
  storagePath   String
  mimeType      String
  fileSize      Int
  parsedContent String?   @db.Text
  parseStatus   String    @default("pending") // pending, parsing, completed, failed
  parsedAt      DateTime?
  createdAt     DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  sessionId String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([timestamp])
}
